# Rook-managed NFS-Ganesha cluster that exports CephFS over NFS.
# Listens on the K8s node network so workloads outside the pod network
# (e.g. Nova tenant VMs) can reach the export.
---
apiVersion: ceph.rook.io/v1
kind: CephNFS
metadata:
  name: {{ ceph_nfs_cluster_id }}
  namespace: {{ ceph_cluster_namespace }}
spec:
  server:
    active: 1
    priorityClassName: system-cluster-critical
    hostNetwork: true
    # Keep Ganesha off the control-plane node. The host nginx tcp proxy
    # listens on tcpproxy_nfs_ganesha_cidr:2049 on the primary, and a
    # Ganesha pod scheduled there would already bind 0.0.0.0:2049 via
    # hostNetwork, causing the proxy to fail with "Address in use".
    placement:
      nodeAffinity:
        requiredDuringSchedulingIgnoredDuringExecution:
          nodeSelectorTerms:
            - matchExpressions:
                - key: node-role.kubernetes.io/control-plane
                  operator: DoesNotExist
